# LLM API configuration (supports any OpenAI-compatible API)
# Recommended: Alibaba Bailian qwen-plus model: https://bailian.console.aliyun.com/
# Model usage can be expensive. Start with simulations under 40 rounds.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep memory graph configuration =====
# The free monthly quota is usually enough for light usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM configuration (optional) =====
# If you are not using acceleration, omit the following variables entirely.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here